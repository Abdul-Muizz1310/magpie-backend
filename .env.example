# ─── Core ──────────────────────────────────────────
APP_ENV=development                    # development | staging | production
LOG_LEVEL=debug                        # debug | info | warn | error
PORT=8000

# ─── Database (Neon — scrape branch) ──────────────
DATABASE_URL=postgresql+asyncpg://user:pw@ep-xyz.neon.tech/scrape?sslmode=require

# ─── Cloudflare R2 (raw HTML snapshots) ───────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=muizz-lab
R2_PREFIX=scrape/

# ─── LLM (OpenRouter — healer) ───────────────────
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL_PRIMARY=              # JSON-mode capable, picked at integration time
OPENROUTER_SITE_URL=https://github.com/Abdul-Muizz1310
OPENROUTER_APP_NAME=muizz-lab-portfolio

# ─── GitHub (healer PR creation) ─────────────────
GITHUB_PAT_SCRAPE_HEALER=ghp_...      # fine-grained PAT: contents:write + pull-requests:write on magpie-backend only
GITHUB_REPO=Abdul-Muizz1310/magpie-backend
GITHUB_HEAL_LABEL=scrape:self-heal

# ─── Observability ────────────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com

# ─── Scraping ─────────────────────────────────────
SCRAPE_RATE_RPS=1
PLAYWRIGHT_HEADLESS=true
